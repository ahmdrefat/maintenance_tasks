<% content_for :page_title, @task %>
<% content_for :breadcrumb do %>
  <span class="navbar-breadcrumb-current"><%= @task %></span>
<% end %>

<%
  parameter_names = @task.parameter_names
  has_form_fields = @task.csv_task? || parameter_names.any?
  latest_run = @task.active_runs.first || @task.runs_page.records.first
%>

<% if latest_run || @task.tags.any? %>
  <%# Task name is in the breadcrumb. This strip is the at-a-glance status. %>
  <header class="task-header">
    <div class="task-header-meta">
      <% if latest_run %>
        <%= status_tag(latest_run.status) %>
        <span class="task-header-meta-text">
          Last ran <%= time_ago(latest_run.created_at) %>
        </span>
      <% end %>
      <% if @task.tags.any? %>
        <span class="task-header-tags">
          <% @task.tags.each do |tag_name| %>
            <span class="task-header-tag"><%= tag_name %></span>
          <% end %>
        </span>
      <% end %>
    </div>
  </header>
<% end %>

<% if @task.deleted? %>
  <div class="notification is-warning is-light" role="status">
    This task no longer exists in the codebase. <strong>Run, Pause, Resume, and Cancel actions are disabled</strong> until it is restored.
  </div>
<% end %>

<%= tag.div(data: { refresh: @task.refresh? || "", "refresh-interval": 3000 }) do %>
  <% if @task.active_runs.any? %>
    <section class="task-section task-active-runs">
      <h2 class="task-section-label">Active runs</h2>
      <%= render partial: "maintenance_tasks/runs/run", collection: @task.active_runs %>
    </section>
  <% end %>
<% end %>

<section class="task-section task-run-form">
  <h2 class="task-section-label">New run</h2>
  <%# Frame the form in a card only when there ARE controls to frame. A %>
  <%# parameter-less task gets the Run button inline so the chrome doesn't %>
  <%# enclose empty space. %>
  <% form_html = capture do %>
    <%= form_with url: task_runs_path(@task), method: :post do |form| %>
      <% if @task.csv_task? %>
        <div class="field mb-4">
          <%= form.label :csv_file, "CSV file", class: "label" %>
          <div class="control">
            <%= form.file_field :csv_file, accept: "text/csv", class: "csv-file-input" %>
          </div>
        </div>
      <% end %>
      <% if parameter_names.any? %>
        <div class="grid is-col-min-15">
          <%= fields_for :task, @task.new do |ff| %>
            <% parameter_names.each do |parameter_name| %>
              <div class="cell">
                <%= ff.label parameter_name, parameter_name, class: ["label", "is-family-monospace", { "is-required": attribute_required?(ff.object, parameter_name) }] %>
                <%= parameter_field(ff, parameter_name) %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <%= render "maintenance_tasks/tasks/custom", form: form %>
      <div class="task-run-card-actions">
        <%= form.submit "Run task", class: "button is-primary", disabled: @task.deleted? %>
      </div>
    <% end %>
  <% end %>
  <% if has_form_fields %>
    <div class="task-run-card"><%= form_html %></div>
  <% else %>
    <div class="task-run-inline"><%= form_html %></div>
  <% end %>
</section>

<% if (code = @task.code) %>
  <section class="task-section task-source-code-section">
    <details class="task-source-code">
      <summary>
        <span class="task-source-code-title">Source code</span>
      </summary>
      <pre><code><%= highlight_code(code) %></code></pre>
    </details>
  </section>
<% end %>

<%= tag.div(data: { refresh: @task.refresh? || "", "refresh-interval": 3000 }) do %>
  <% if @task.runs_page.records.present? %>
    <section class="task-section task-previous-runs">
      <h2 class="task-section-label">Previous runs</h2>

      <%# Compress succeeded/cancelled runs to a one-line summary; keep %>
      <%# errored/paused/cancelling runs full-fat so failures stand out. %>
      <% @task.runs_page.records.each do |run| %>
        <% if ["succeeded", "cancelled"].include?(run.status) %>
          <%= render "maintenance_tasks/runs/run_summary", run: run %>
        <% else %>
          <%= render "maintenance_tasks/runs/run", run: run %>
        <% end %>
      <% end %>

      <%= link_to "Next page", task_path(@task, cursor: @task.runs_page.next_cursor), class: "pagination-link" unless @task.runs_page.last? %>
    </section>
  <% end %>
<% end %>
