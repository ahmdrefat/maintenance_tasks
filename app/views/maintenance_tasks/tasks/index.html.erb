<% if @tasks.empty? %>
  <div class="task-empty" role="region" aria-labelledby="task-empty-title">
    <div class="task-empty-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="16" rx="2"></rect>
        <path d="M3 9h18"></path>
        <path d="M8 14h6"></path>
        <path d="M8 17h4"></path>
      </svg>
    </div>
    <h2 id="task-empty-title" class="task-empty-title">No maintenance tasks yet</h2>
    <p class="task-empty-sub">Generate your first task to start running scheduled jobs from this dashboard.</p>
    <div class="task-empty-cmd">
      <code>bin/rails g maintenance_tasks:task my_task</code>
      <button type="button"
              class="task-empty-copy"
              data-copy="bin/rails g maintenance_tasks:task my_task"
              aria-label="Copy command to clipboard">⎘</button>
    </div>
    <a class="task-empty-doc"
       href="https://github.com/Shopify/maintenance_tasks#usage"
       target="_blank"
       rel="noopener noreferrer">Read the docs →</a>
  </div>
<% else %>
  <% content_for :navbar_search do %>
    <div class="task-search-wrap">
      <span class="task-filter-count" role="status" aria-live="polite"></span>
      <div class="task-search-field">
        <input type="search"
               id="task-search"
               class="task-search"
               placeholder="Search tasks…"
               aria-label="Search tasks by name"
               autocomplete="off"
               autocapitalize="off"
               spellcheck="false">
      </div>
    </div>
  <% end %>

  <% if @tag_filters.any? %>
    <div class="task-toolbar mb-4">
      <div class="tag-filters" role="group" aria-label="Filter tasks by tag">
        <% @tag_filters.each do |tag_name| %>
          <button type="button"
                  class="tag-filter tag is-medium"
                  data-tag="<%= tag_name %>"
                  aria-pressed="false">
            <%= tag_name %>
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

  <p class="task-empty-results has-text-grey is-italic mb-4" hidden role="status">
    No tasks match the current filters.
  </p>

  <%# Never-run tasks lead so a freshly-defined task is immediately discoverable; %>
  <%# tasks with prior runs follow, sorted by their existing recency order. Each %>
  <%# never-run task gets a "New" status pill rendered by _task.html.erb. %>
  <% with_runs, never_run = @tasks.partition(&:related_run) %>
  <% ordered_tasks = never_run + with_runs %>

  <%= tag.div(data: { refresh: (defined?(@refresh) && @refresh) || "" }) do %>
    <div class="table-container">
      <table class="task-table table is-fullwidth is-hoverable">
        <thead>
          <tr>
            <th scope="col">Task</th>
            <th scope="col">Tags</th>
            <th scope="col" class="task-col-last-run">Last run</th>
          </tr>
        </thead>
        <tbody>
          <%= render partial: "task", collection: ordered_tasks %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
