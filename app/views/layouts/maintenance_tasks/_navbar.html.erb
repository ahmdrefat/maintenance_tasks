<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="navbar-inner">
    <div class="navbar-brand">
      <%= link_to root_path, class: "navbar-item brand-link" do %>
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a4.5 4.5 0 0 0-6.4 6.4l-6 6 2 2 6-6a4.5 4.5 0 0 0 6.4-6.4l-2.8 2.8-2-2 2.8-2.8z"/>
          </svg>
        </span>
        <span class="brand-text">Maintenance Tasks</span>
      <% end %>
      <% if content_for?(:breadcrumb) %>
        <span class="navbar-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="navbar-breadcrumb"><%= yield :breadcrumb %></span>
      <% end %>
    </div>
    <% if content_for?(:navbar_search) %>
      <div class="navbar-middle"><%= yield :navbar_search %></div>
    <% end %>
    <div class="navbar-end">
      <span class="navbar-item">
        <span class="navbar-refresh-indicator"
              id="refresh-indicator"
              role="status"
              aria-live="polite"
              aria-label="Auto-refresh idle"
              title="Auto-refresh"></span>
      </span>
      <span class="navbar-item">
        <button type="button"
                id="theme-toggle"
                class="theme-toggle"
                aria-label="Toggle color theme"
                title="Toggle color theme">
          <span class="theme-toggle-icon" aria-hidden="true"></span>
        </button>
      </span>
    </div>
  </div>
</nav>
